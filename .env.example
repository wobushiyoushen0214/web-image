RELAY_BASE_URL=https://freeapi.dgbmc.top/v1
RELAY_API_KEY=sk-xxx
RELAY_MODELS=gpt-image-2
RELAY_EDIT_MODELS=gpt-image-2
# Optional model-specific API keys. Format: model=key,another-model=another-key
RELAY_MODEL_API_KEYS=grok-imagine-image-lite=sk-xxx

# AI 美化（可选）。不填则复用 RELAY_BASE_URL / RELAY_API_KEY
ENHANCE_BASE_URL=
ENHANCE_API_KEY=
ENHANCE_MODELS=moonshotai/kimi-k2.5,minimaxai/minimax-m2.7

# 反推 prompt（图→词），需是支持图像输入的多模态模型
DESCRIBE_MODEL=z-ai/glm-4.5v

RATE_LIMIT_PER_HOUR=20
KV_REST_API_URL=
KV_REST_API_TOKEN=
